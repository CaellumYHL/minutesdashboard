# Minutes Dashboard - Environment Configuration Template
# Instructions: Copy this file to .env and fill in your values.
# IMPORTANT: Vite requires variables to be prefixed with VITE_ to be accessible in the client.

# GitHub Personal Access Token (Fine-grained token with "Workflows" write access recommended)
VITE_GITHUB_TOKEN=your_github_pat_here

# Repository Information
VITE_REPO_OWNER=Caleb-Gawthroupe
VITE_REPO_NAME=minutes
